rules_version = '2';

// TODO(MVP): rozdzielić pola zapisywane tylko przez Cloud Functions (AI) od pól
// aktualizowanych przez klienta — obecnie klient może nadpisać `vehicle_info` przy ponownym syncu.

service cloud.firestore {
  match /databases/{database}/documents {
    // Profil użytkownika + prywatne skany — tylko właściciel (request.auth.uid).
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /scans/{scanId} {
        allow read, write: if request.auth != null
          && request.auth.uid == userId
          && scanId.size() > 0
          && scanId.size() <= 128;
      }
    }
  }
}
